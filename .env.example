# ── LLM Provider ────────────────────────────────────────────────────────────
# Pick one. ADK uses GOOGLE_API_KEY by default; for others, wire in litellm.
GOOGLE_API_KEY=your-google-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite+aiosqlite:///./helix_srop.db
# Postgres (for Postgres-compatible schema):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/helix_srop

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
# LANCEDB_PATH=./lancedb
# PINECONE_API_KEY=...
# PINECONE_INDEX=helix-docs

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-prod     # used for JWT signing (extension E2)

# ── Model Selection ───────────────────────────────────────────────────────────
# Which model the ADK agents use. Gemini Flash is fast + cheap for dev.
ADK_MODEL=gemini-flash-latest    # or: gemini-2.5-flash-lite, gemini-pro-latest

# ── Agent Timeouts ────────────────────────────────────────────────────────────
LLM_TIMEOUT_SECONDS=90       # ADK orchestrator + sub-agent + RAG can take ~20-60s
TOOL_TIMEOUT_SECONDS=10

# ── E4: LLM-as-judge reranker ────────────────────────────────────────────────
# Fetch top-N from Chroma, rerank with Gemini, return top-k.
# Off by default (extra LLM call per knowledge query). Recall-at-3 lift on
# our 5-query golden set is documented in the README.
RERANKER_ENABLED=false
RERANKER_TOP_N=20
RERANKER_MODEL=gemini-flash-latest

# ── OpenTelemetry ────────────────────────────────────────────────────────────
# Spans wrap pipeline.run, ADK agent run, and each tool call. Off by default
# (the SDK is installed but the tracer provider stays no-op until enabled).
OTEL_ENABLED=false
OTEL_CONSOLE_EXPORTER=false                  # print spans to stdout for demos
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # ship to Jaeger / OTLP
OTEL_SERVICE_NAME=helix-srop

# ── Vector store backend ──────────────────────────────────────────────────────
# ``chroma`` (default, local file-based) or ``pgvector`` (Postgres extension).
# pgvector requires `pip install -e ".[pgvector]"` and a running Postgres.
VECTOR_STORE_BACKEND=chroma
# PGVECTOR_DATABASE_URL=postgresql://helix:helix@localhost:5432/helix_srop
PGVECTOR_TABLE=helix_doc_chunks
